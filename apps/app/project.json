{
  "root": "apps/app",
  "sourceRoot": "apps/app",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/web:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "babel",
        "outputPath": "dist/apps/app",
        "index": "apps/app/public/index.html",
        "baseHref": "/",
        "main": "apps/app/src/main.tsx",
        "polyfills": "apps/app/src/polyfills.ts",
        "tsConfig": "apps/app/tsconfig.json",
        "assets": [
          "apps/app/public/assets",
          "apps/app/public/favicon"
        ],
        "styles": [],
        "scripts": [],
        "webpackConfig": "webpackConfig.js"
      },
      "configurations": {
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/app/src/environments/environment.ts",
              "with": "apps/app/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "serve": {
      "executor": "@nrwl/web:dev-server",
      "options": {
        "buildTarget": "app:build",
        "hmr": true,
        "port": 3002,
        "allowedHosts": "localhost,portals.lvh.me,fe.npmdev.net,portals.npmdev.net"
      },
      "configurations": {
        "production": {
          "buildTarget": "app:build:production",
          "hmr": false,
          "host": "0.0.0.0",
          "allowedHosts": "localhost,portals.lvh.me,fe.npmdev.net,portals.npmdev.net",
          "port": 3002
        }
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/app/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "typecheck": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          {
            "command": "tsc --noEmit -p ./apps/app/tsconfig.json"
          },
          {
            "command": "tsc --noEmit -p ./apps/app/tsconfig.spec.json"
          }
        ]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/apps/app"],
      "options": {
        "jestConfig": "apps/app/jest.config.js",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
